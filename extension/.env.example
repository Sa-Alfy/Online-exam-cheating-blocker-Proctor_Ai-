# Extension Backend Configuration
# Copy this file to .env to configure the extension build

# Backend server URL (the URL where your Flask backend is hosted)
# Local development: http://localhost:5000
# PythonAnywhere: http://your-id.pythonanywhere.com/
# Do NOT include trailing slash
BACKEND_URL=http://localhost:5000

# Environment mode (for future use if needed)
# Values: 'development' or 'production'
ENV_MODE=development

