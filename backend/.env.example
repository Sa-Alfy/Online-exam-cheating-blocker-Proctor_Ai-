# ============================================================================
# Proctor AI Backend — Environment Configuration (Windows/Linux/Mac)
# ============================================================================
# Copy this file to .env (in backend/ directory) and fill in your values.
# IMPORTANT: .env is in .gitignore and must NEVER be committed.
# This file is loaded automatically by config.py when the app starts.
# ============================================================================

# --- Flask Settings ---
FLASK_ENV=development

# --- Deployment Target ---
# Set to 'local' for local development or 'pythonanywhere' for production
DEPLOY_ENV=local

# --- Data Directory ---
# Absolute path where database (proctor.db) and logs are stored
# Local (Windows):     C:\Users\YourName\Code\proctor_project\backend
# PythonAnywhere:      /home/your-username
# Leave empty to default to the backend/ directory
DATA_DIR=

# --- Security (CRITICAL FOR PRODUCTION) ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
# Change this in production - do NOT use the default in production!
SECRET_KEY=change-me-in-production

# --- Database Configuration ---
DATABASE_PATH=proctor.db
DATABASE_TIMEOUT=30

# --- Server Configuration ---
HOST=127.0.0.1
PORT=5000

# --- CORS (Cross-Origin Resource Sharing) ---
# Comma-separated list of allowed origins for API requests from the extension
# 
# Local development:
#   CORS_ORIGINS=http://127.0.0.1:*,http://localhost:*
#
# PythonAnywhere production:
#   CORS_ORIGINS=https://your-id.pythonanywhere.com,chrome-extension://EXTENSION_ID
#
# Where EXTENSION_ID is your Chrome extension's ID (found in chrome://extensions/)
CORS_ORIGINS=http://127.0.0.1:*,http://localhost:*

# --- Rate Limiting ---
# Maximum API requests per student per minute
MAX_REQUESTS_PER_MINUTE=60
REQUEST_TIMEOUT=30
MAX_CONTENT_LENGTH=16777216

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=proctor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- Violation Tracking ---
# How many violations per student per minute before excessive alert
MAX_VIOLATIONS_PER_STUDENT_PER_MINUTE=10
# How long to keep violation records (in days)
VIOLATION_RETENTION_DAYS=30

