# ============================================================================
# Proctor AI — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# IMPORTANT: .env is in .gitignore and must NEVER be committed.
# ============================================================================

# --- Flask ---
FLASK_ENV=development

# --- Deployment ---
# Set to 'pythonanywhere' when deploying to PythonAnywhere
DEPLOY_ENV=local

# Absolute path where DB + logs are stored.
# Local default: the backend/ directory itself. On PythonAnywhere: /home/<username>
# DATA_DIR=/home/your-username
DATA_DIR=

# --- Security ---
# Generate a strong random key for production:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# --- Database ---
DATABASE_PATH=proctor.db
DATABASE_TIMEOUT=30

# --- Server ---
HOST=127.0.0.1
PORT=5000

# --- CORS ---
# Comma-separated allowed origins. In production, add your domain:
# CORS_ORIGINS=https://your-user.pythonanywhere.com,chrome-extension://your-extension-id
CORS_ORIGINS=http://127.0.0.1:*,http://localhost:*

# --- Rate Limiting ---
MAX_REQUESTS_PER_MINUTE=60
REQUEST_TIMEOUT=30
MAX_CONTENT_LENGTH=16777216

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=proctor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- Violation Tracking ---
MAX_VIOLATIONS_PER_STUDENT_PER_MINUTE=10
VIOLATION_RETENTION_DAYS=30

# --- Pagination ---
VIOLATIONS_PER_PAGE=100
MAX_VIOLATIONS_FETCH=1000
